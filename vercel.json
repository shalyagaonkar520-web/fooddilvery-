{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api|sitemap\\.xml|robots\\.txt|.*\\..*).*)", "destination": "/index.html" }
  ]
}
